# 1. 环境变量与敏感密钥 (绝对不能上传)
.env
*.env
.env.*

# 2. Python 虚拟环境 (体积大、跨平台不兼容，不需要上传)
.venv/
venv/
env/
ENV/

# 3. 数据库文件 (保护你的私人日程数据不被公开)
schedule.db
*.sqlite3
*.db

# 4. Python 运行时生成的缓存文件 (无需上传)
__pycache__/
*.py[cod]
*$py.class
*.so

# 5. IDE 配置文件 (避免团队协作时配置冲突)
.vscode/
.idea/
*.swp
*.swo

# 6. 操作系统生成的隐藏文件
.DS_Store
Thumbs.db